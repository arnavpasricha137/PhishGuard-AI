# PhishGuard AI Backend Configuration

# Redis Configuration
REDIS_URL=redis://localhost:6379

# API Keys (add your keys here)
PHISHTANK_API_KEY=

# Server Configuration
BACKEND_PORT=8000
LOG_LEVEL=INFO

# CORS Origins (JSON array)
CORS_ORIGINS=["chrome-extension://*","http://localhost:3000"]

# Agent Configuration
AGENT_TIMEOUT=10
CACHE_TTL=86400

# ML Model
MODEL_NAME=ealvaradob/bert-finetuned-phishing

# External APIs
EXTERNAL_API_TIMEOUT=3
